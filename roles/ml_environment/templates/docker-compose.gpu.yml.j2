version: "3.8"
services:
  # ── Training container ─────────────────────
  train:
    image: nvcr.io/nvidia/pytorch:24.12-py3
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
    volumes:
      - ./data:/workspace/data
      - ./checkpoints:/workspace/checkpoints
      - ./logs:/workspace/logs
    working_dir: /workspace
    shm_size: "8g"
    stdin_open: true
    tty: true

  # ── Jupyter Lab ────────────────────────────
  jupyter:
    image: nvcr.io/nvidia/pytorch:24.12-py3
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: 1
              capabilities: [gpu]
    ports:
      - "8888:8888"
    volumes:
      - ./notebooks:/workspace/notebooks
      - ./data:/workspace/data:ro
    command: >
      jupyter lab --ip=0.0.0.0 --port=8888
      --allow-root --no-browser
      --NotebookApp.token='gpu-lab'
    profiles: ["dev"]

  # ── GPU Monitoring (DCGM exporter) ─────────
  dcgm-exporter:
    image: nvcr.io/nvidia/k8s/dcgm-exporter:3.3.5-3.4.1-ubuntu22.04
    deploy:
      resources:
        reservations:
          devices:
            - capabilities: [gpu]
    ports:
      - "9400:9400"
    profiles: ["monitor"]
